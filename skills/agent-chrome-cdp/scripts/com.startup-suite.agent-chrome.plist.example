<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd template for the dedicated agent Chrome on macOS.

  Copy to ~/Library/LaunchAgents/com.startup-suite.agent-chrome.plist, edit
  ProgramArguments to point at your Chrome binary and profile dir, then:

    launchctl load -w ~/Library/LaunchAgents/com.startup-suite.agent-chrome.plist
    launchctl list | grep agent-chrome
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.startup-suite.agent-chrome</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Applications/Google Chrome.app/Contents/MacOS/Google Chrome</string>
    <string>--remote-debugging-port=9222</string>
    <string>--remote-debugging-address=127.0.0.1</string>
    <string>--user-data-dir=/Users/REPLACE_ME/Library/Caches/agent-chrome-profile</string>
    <string>--no-first-run</string>
    <string>--no-default-browser-check</string>
    <string>--disable-background-networking</string>
    <string>--disable-default-apps</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/REPLACE_ME/Library/Logs/agent-chrome.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/REPLACE_ME/Library/Logs/agent-chrome.log</string>
</dict>
</plist>
